    "POST /api/agents/topics/:id/run - Generate concept pathways",
    "POST /api/agents/concepts/:id/run - Run adaptive refinement",
    "POST /api/chat/sessions/:id/tutor - Interactive tutoring",
    "GET /api/assessments/:id - Retrieve diagnostic assessments",
    "POST /api/assessments/:id/answers - Submit answers",
    "GET /api/progress/:userId/:nodeId - Track learning progress",
    "POST /api/nodes/:id/documents - Upload learning materials"
